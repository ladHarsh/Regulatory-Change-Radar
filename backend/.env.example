# ============================================================
# Regulatory Change Radar — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM (Groq) ---
# Get your free key at https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- LLM (Ollama local fallback) ---
# Install Ollama from https://ollama.com and run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Which LLM to use: "groq" or "ollama" ---
LLM_PROVIDER=groq

# --- Embedding Model (downloaded locally on first run, ~130MB) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Reranker Model (downloaded locally on first run, ~85MB) ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Data Directories ---
DATA_DIR=./data
CHROMA_DIR=./data/chroma
SQLITE_URL=sqlite:///./data/radar.db

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# --- Semantic Diff Thresholds ---
DIFF_UNCHANGED_THRESHOLD=0.95
DIFF_MODIFIED_THRESHOLD=0.75

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
